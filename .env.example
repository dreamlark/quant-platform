# ===== A 股日频量化分析平台 · 环境变量样例 =====
# 复制为 .env 后填入真实值；禁止把密钥硬编码进代码。

# --- LLM (DeepSeek V3, OpenAI 兼容) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_CACHE_ENABLED=true

# --- 调度 ---
SCHEDULER_ENABLED=false
SCHEDULE_CRON=30 18 * * 1-5      # 盘后 18:30，周一至周五（避 DeepSeek 峰谷）
TZ=Asia/Shanghai

# --- 路径（可选，默认使用仓库内 data/）---
# DATA_DIR=./data
# MARKET_DB=./data/market.duckdb
# ANALYTICS_DB=./data/analytics.duckdb

# --- 多源数据（可选覆盖）---
# DATA_SOURCE_PRIORITY=mootdx,akshare,baostock
